# Copy this file to `keystore.properties` (same folder) and fill in your values.
# `keystore.properties` is gitignored — never commit it, and never share it.
#
# After you create your upload keystore (see the deploy guide), set:
#   storeFile     = the path to your .jks file (absolute path is safest)
#   storePassword = the keystore password you chose
#   keyAlias      = the alias you chose (e.g. upload)
#   keyPassword   = the key password you chose

storeFile=/absolute/path/to/salestracker-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
